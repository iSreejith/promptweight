# Simulated preview of the statusline inside Claude Code (CLI / VS Code
# integrated terminal — same UI). Frames live in docs/mockup/.
Output docs/demo-statusline.gif

Set FontSize 18
Set Width 1100
Set Height 620
Set Theme "Catppuccin Mocha"
Set TypingSpeed 30ms
Set Shell bash

Type "# simulated preview — promptweight statusline inside Claude Code (CLI & VS Code)"
Sleep 800ms
Enter
Sleep 400ms

Hide
Type "clear && cat /vhs/docs/mockup/frame1.txt" Enter
Show
Sleep 6s

Hide
Type "clear && cat /vhs/docs/mockup/frame2.txt" Enter
Show
Sleep 6s
Sleep 3s
